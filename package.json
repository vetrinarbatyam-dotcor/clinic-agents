{
  "name": "clinic-agents",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "followup-agents",
    "debt-agent",
    "vaccine-reminders",
    "remind-agent",
    "dashboard",
    "petconnect",
    "data-warehouse",
    "marpet-reminder"
  ],
  "scripts": {
    "followup": "bun run followup-agents/src/index.ts",
    "followup:dry": "bun run followup-agents/src/index.ts --dry-run",
    "debt": "bun run debt-agent/src/index.ts",
    "debt:dry": "bun run debt-agent/src/index.ts --dry-run",
    "vaccine": "bun run vaccine-reminders/src/index.ts",
    "vaccine:dry": "bun run vaccine-reminders/src/index.ts --dry-run",
    "remind": "bun run remind-agent/src/index.ts",
    "remind:dry": "bun run remind-agent/src/index.ts --dry-run",
    "remind:deep": "bun run remind-agent/src/index.ts --deep-scan",
    "remind:deep:dry": "bun run remind-agent/src/index.ts --deep-scan --dry-run",
    "dashboard:dev": "cd dashboard && bun run dev",
    "dashboard:build": "cd dashboard && bun run build",
    "vaccine:api": "bun run vaccine-reminders/src/api.ts",
    "petconnect": "bun run petconnect/src/index.ts",
    "petconnect:dry": "bun run petconnect/src/index.ts --dry-run",
    "petconnect:sync": "bun run petconnect/src/sync-clients.ts",
    "petconnect:sync:details": "bun run petconnect/src/sync-clients.ts --only-details",
    "petconnect:templates": "bun run petconnect/src/index.ts --list-templates",
    "petconnect:api": "bun run petconnect/src/api.ts",
    "warehouse": "bun run data-warehouse/src/sync-warehouse.ts",
    "warehouse:initial": "bun run data-warehouse/src/sync-warehouse.ts initial 7",
    "warehouse:hourly": "bun run data-warehouse/src/sync-warehouse.ts hourly",
    "warehouse:daily": "bun run data-warehouse/src/sync-warehouse.ts daily",
    "warehouse:weekly": "bun run data-warehouse/src/sync-warehouse.ts weekly",
    "warehouse:therapists": "bun run data-warehouse/src/sync-warehouse.ts therapists",
    "warehouse:appointments": "bun run data-warehouse/src/sync-warehouse.ts appointments",
    "marpet": "bun run marpet-reminder/src/index.ts",
    "marpet:dry": "bun run marpet-reminder/src/index.ts --dry-run",
    "marpet:refresh-tz": "bun run marpet-reminder/src/index.ts --dry-run --force-refresh-tz"
  },
  "dependencies": {
    "@hebcal/core": "^6.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.0",
    "pg": "^8.20.0"
  }
}